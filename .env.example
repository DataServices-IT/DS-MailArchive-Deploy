# ============================================================
#  DataMail Archive — Variables d'environnement client
#  Copier ce fichier : cp .env.example .env
#  Puis modifier les valeurs avant de lancer docker compose
# ============================================================

# ── Mot de passe base de données PostgreSQL (OBLIGATOIRE — changer avant démarrage)
DB_PASSWORD=ChangeMoi_MotDePasseDB!

# ── Accès interface web admin (OBLIGATOIRE — changer avant démarrage)
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeMoi_MotDePasseAdmin!

# ── Port HTTP exposé sur l'hôte (80 pour production, 8080 si port 80 déjà pris)
APP_PORT=80

# ── Fuseau horaire
TIMEZONE=Europe/Paris

# ── Synchronisation IMAP (toutes les X minutes)
SYNC_INTERVAL=15

# ── Rétention des backups (en jours)
BACKUP_KEEP_DAYS=30
